<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--   USER GROUPS   -->

    <!-- Group 1: Library User (read only) -->
    <record id="group_library_user" model="res.groups">
        <field name="name">Library / User</field>
        <field name="implied_ids"
               eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Group 2: Library Librarian (full access) -->
    <record id="group_library_librarian" model="res.groups">
        <field name="name">Library / Librarian</field>
        <field name="implied_ids"
               eval="[(4, ref('group_library_user'))]"/>
    </record>

    <!-- Group 3: Library Manager (admin) -->
    <record id="group_library_manager" model="res.groups">
        <field name="name">Library / Manager</field>
        <field name="implied_ids"
               eval="[(4, ref('group_library_librarian'))]"/>
    </record>

    <!-- ============================================================
         RECORD RULES
    ============================================================ -->

    <!-- Users can only see non-lost books -->
    <record id="rule_library_book_user" model="ir.rule">
        <field name="name">Library Book: Users see available only</field>
        <field name="model_id" ref="model_library_book"/>
        <field name="groups" eval="[(4, ref('group_library_user'))]"/>
        <field name="domain_force">[('state', '!=', 'lost')]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Librarians can see all books -->
    <record id="rule_library_book_librarian" model="ir.rule">
        <field name="name">Library Book: Librarians see all</field>
        <field name="model_id" ref="model_library_book"/>
        <field name="groups" eval="[(4, ref('group_library_librarian'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>