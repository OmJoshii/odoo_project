<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Books">
                <field name="name"/>
                <field name="author_id"/>
                <field name="isbn"/>
                <field name="pages"/>
                <field name="price"/>
                <field name="state"/>
                <field name="is_available"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_library_book_kanban" model="ir.ui.view">
        <field name="name">library.book.kanban</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="author_id"/>
                <field name="state"/>
                <field name="price"/>
                <field name="is_available"/>
                <field name="author_nationality"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <span class="text-muted">Author: </span>
                                    <field name="author_id"/>
                                </div>
                                <div>
                                    <span class="text-muted">Nationality: </span>
                                    <field name="author_nationality"/>
                                </div>
                                <div>
                                    <span class="text-muted">Price: </span>
                                    <field name="price"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="is_available"
                                           widget="boolean_toggle"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state"
                                           widget="badge"
                                           decoration-success="state == 'available'"
                                           decoration-warning="state == 'borrowed'"
                                           decoration-danger="state == 'lost'"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Book">
                <header>
                    <button
                        string="Borrow"
                        type="object"
                        name="action_open_borrow_wizard"
                        class="btn-primary"
                        invisible="state != 'available'"/>
                    <button
                        string="Return Book"
                        type="object"
                        name="action_return_book"
                        class="btn-secondary"
                        invisible="state != 'borrowed'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="available,borrowed,lost"/>
                    <button
                        string="Print Report"
                        type="object"
                        name="action_print_report"
                        class="btn-secondary"/>
                </header>

                <div class="oe_button_box" name="button_box">
                    <button type="object"
                            name="action_view_borrow_requests"
                            class="oe_stat_button"
                            icon="fa-list">
                        <field name="borrow_request_count"
                               widget="statinfo"
                               string="Requests"/>
                    </button>
                </div>
                <sheet>
                    <group>
                        <group string="Book Information">
                            <field name="name"/>
                            <field name="author_id"/>
                            <field name="author_nationality"/>
                            <field name="isbn"/>
                            <field name="date_published"/>
                        </group>
                        <group string="Details">
                            <field name="pages"/>
                            <field name="price"/>
                            <field name="is_available"/>
                        </group>
                    </group>
                    <group string="Categories">
                        <field name="category_ids"
                               widget="many2many_tags"
                               nolabel="1"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_library_book_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search string="Search Books">
                <field name="name" string="Title"
                       filter_domain="[('name','ilike',self)]"/>
                <field name="author_id" string="Author"/>
                <field name="isbn" string="ISBN"
                       filter_domain="[('isbn','=',self)]"/>
                <field name="category_ids" string="Category"/>
                <filter string="Available" name="filter_available"
                        domain="[('state','=','available')]"/>
                <filter string="Borrowed" name="filter_borrowed"
                        domain="[('state','=','borrowed')]"/>
                <filter string="Lost" name="filter_lost"
                        domain="[('state','=','lost')]"/>
                <separator/>
                <filter string="Is Available" name="filter_is_available"
                        domain="[('is_available','=',True)]"/>
                <filter string="Not Available" name="filter_not_available"
                        domain="[('is_available','=',False)]"/>
                <separator/>
                <filter string="Has No Author" name="filter_no_author"
                        domain="[('author_id','=',False)]"/>
                <separator/>
                <filter string="Author" name="group_by_author"
                        context="{'group_by':'author_id'}"/>
                <filter string="Status" name="group_by_state"
                        context="{'group_by':'state'}"/>
                <filter string="Category" name="group_by_category"
                        context="{'group_by':'category_ids'}"/>
                <filter string="Published Date" name="group_by_date"
                        context="{'group_by':'date_published:month'}"/>
                <searchpanel>
                    <field name="state" string="Status"
                           select="one" icon="fa-circle"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- WINDOW ACTION -->
    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Books</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{
            'search_default_filter_available': 1
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first book!
            </p>
            <p>Start building your library by adding books.</p>
        </field>
    </record>

    <!-- AUTHOR ACTIONS -->
    <record id="action_library_author" model="ir.actions.act_window">
        <field name="name">Authors</field>
        <field name="res_model">library.author</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- CATEGORY ACTION -->
    <record id="action_library_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">library.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MEMBERS ACTION -->
    <record id="action_library_members" model="ir.actions.act_window">
        <field name="name">Library Members</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_library_member','=',True)]</field>
        <field name="context">{'default_is_library_member': True}</field>
    </record>

    <!--     BORROW REQUEST — WINDOW ACTION    -->
    <record id="action_library_borrow_requests"
            model="ir.actions.act_window">
        <field name="name">Borrow Requests</field>
        <field name="res_model">library.borrow.request</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">
            {'search_default_filter_pending': 1}
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No borrow requests yet!
            </p>
            <p>
                Requests submitted from the website
                will appear here.
            </p>
        </field>
    </record>

    <!-- MENUS -->
    <menuitem id="menu_library_root"
              name="Library"
              sequence="10"
              groups="library_management.group_library_user"/>

    <menuitem id="menu_library_books_section"
              name="Books"
              parent="menu_library_root"
              sequence="10"
              groups="library_management.group_library_user"/>

    <menuitem id="menu_library_books"
              name="All Books"
              parent="menu_library_books_section"
              action="action_library_book"
              sequence="10"/>

    <menuitem id="menu_library_authors"
              name="Authors"
              parent="menu_library_books_section"
              action="action_library_author"
              sequence="20"
              groups="library_management.group_library_librarian"/>

    <menuitem id="menu_library_categories"
              name="Categories"
              parent="menu_library_books_section"
              action="action_library_category"
              sequence="30"
              groups="library_management.group_library_librarian"/>

    <menuitem id="menu_library_members_section"
              name="Members"
              parent="menu_library_root"
              sequence="20"
              groups="library_management.group_library_librarian"/>

    <menuitem id="menu_library_members"
              name="All Members"
              parent="menu_library_members_section"
              action="action_library_members"
              sequence="10"/>

    <!-- Borrow Requests Section -->
    <menuitem
        id="menu_library_requests_section"
        name="Requests"
        parent="menu_library_root"
        sequence="30"
        groups="library_management.group_library_librarian"/>

    <menuitem
        id="menu_library_borrow_requests"
        name="Borrow Requests"
        parent="menu_library_requests_section"
        action="action_library_borrow_requests"
        sequence="10"/>

    <!-- AUTHOR LIST VIEW -->
    <record id="view_library_author_list" model="ir.ui.view">
        <field name="name">library.author.list</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <list string="Authors">
                <field name="name"/>
                <field name="nationality"/>
                <field name="email"/>
                <field name="book_count"/>
            </list>
        </field>
    </record>

    <!-- AUTHOR FORM VIEW -->
    <record id="view_library_author_form" model="ir.ui.view">
        <field name="name">library.author.form</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <form string="Author">
                <sheet>
                    <group>
                        <group string="Personal Info">
                            <field name="name"/>
                            <field name="nationality"/>
                            <field name="birthdate"/>
                            <field name="email"/>
                        </group>
                        <group string="Stats">
                            <field name="book_count"/>
                        </group>
                    </group>
                    <group string="Biography">
                        <field name="bio" nolabel="1"/>
                    </group>
                    <group string="Books">
                        <field name="book_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="state"/>
                                <field name="price"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- VIEW INHERITANCE — Extend res.partner form -->
    <record id="view_partner_library_member_form" model="ir.ui.view">
        <field name="name">res.partner.library.member.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal_notes']"
                   position="before">
                <page string="Library Membership"
                      name="library_membership">
                    <group>
                        <group string="Membership Info">
                            <field name="is_library_member"/>
                            <field name="library_card_number"/>
                            <field name="membership_status"/>
                            <field name="is_membership_valid"/>
                        </group>
                        <group string="Membership Dates">
                            <field name="membership_start"/>
                            <field name="membership_end"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- BORROW WIZARD FORM VIEW -->
    <record id="view_library_borrow_wizard_form" model="ir.ui.view">
        <field name="name">library.borrow.wizard.form</field>
        <field name="model">library.borrow.wizard</field>
        <field name="arch" type="xml">
            <form string="Borrow Book">
                <group>
                    <group string="Book Details">
                        <field name="book_id"/>
                        <field name="borrow_date"/>
                        <field name="return_date"/>
                    </group>
                    <group string="Member">
                        <field name="member_id"/>
                    </group>
                </group>
                <group string="Notes">
                    <field name="notes" nolabel="1"/>
                </group>
                <footer>
                    <button string="Confirm Borrow"
                            type="object"
                            name="action_confirm_borrow"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- WIZARD ACTION -->
    <record id="action_library_borrow_wizard"
            model="ir.actions.act_window">
        <field name="name">Borrow Book</field>
        <field name="res_model">library.borrow.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!--   BORROW REQUEST — LIST VIEW   -->
    <record id="view_library_borrow_request_list"
            model="ir.ui.view">
        <field name="name">library.borrow.request.list</field>
        <field name="model">library.borrow.request</field>
        <field name="arch" type="xml">
            <list string="Borrow Requests"
                  decoration-success="state == 'approved'"
                  decoration-warning="state == 'pending'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state == 'returned'">
                <field name="name"/>
                <field name="borrower_name"/>
                <field name="borrower_email"/>
                <field name="book_id"/>
                <field name="borrow_date"/>
                <field name="return_date"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'pending'"
                       decoration-danger="state == 'rejected'"
                       decoration-muted="state == 'returned'"/>
            </list>
        </field>
    </record>

    <!--  BORROW REQUEST — FORM VIEW   -->
    <record id="view_library_borrow_request_form"
            model="ir.ui.view">
        <field name="name">library.borrow.request.form</field>
        <field name="model">library.borrow.request</field>
        <field name="arch" type="xml">
            <form string="Borrow Request">
                <header>
                    <button
                        string="Approve"
                        type="object"
                        name="action_approve"
                        class="btn-primary"
                        invisible="state != 'pending'"/>
                    <button
                        string="Reject"
                        type="object"
                        name="action_reject"
                        class="btn-danger"
                        invisible="state != 'pending'"/>
                    <button
                        string="Mark as Returned"
                        type="object"
                        name="action_return"
                        class="btn-secondary"
                        invisible="state != 'approved'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="pending,approved,returned"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Borrower Information">
                            <field name="borrower_name"/>
                            <field name="borrower_email"/>
                        </group>
                        <group string="Book Information">
                            <field name="book_id"/>
                            <field name="borrow_date"/>
                            <field name="return_date"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--    BORROW REQUEST — SEARCH VIEW   -->
    <record id="view_library_borrow_request_search"
            model="ir.ui.view">
        <field name="name">library.borrow.request.search</field>
        <field name="model">library.borrow.request</field>
        <field name="arch" type="xml">
            <search string="Search Requests">
                <field name="borrower_name" string="Borrower"/>
                <field name="borrower_email" string="Email"/>
                <field name="book_id" string="Book"/>
                <filter string="Pending"
                        name="filter_pending"
                        domain="[('state','=','pending')]"/>
                <filter string="Approved"
                        name="filter_approved"
                        domain="[('state','=','approved')]"/>
                <filter string="Returned"
                        name="filter_returned"
                        domain="[('state','=','returned')]"/>
                <filter string="Rejected"
                        name="filter_rejected"
                        domain="[('state','=','rejected')]"/>
                <separator/>
                <filter string="Book"
                        name="group_by_book"
                        context="{'group_by':'book_id'}"/>
                <filter string="Status"
                        name="group_by_state"
                        context="{'group_by':'state'}"/>
                <filter string="Borrow Date"
                        name="group_by_date"
                        context="{'group_by':'borrow_date:month'}"/>
            </search>
        </field>
    </record>

    <!--   BORROW REQUEST — KANBAN VIEW -->
    <record id="view_library_borrow_request_kanban"
            model="ir.ui.view">
        <field name="name">library.borrow.request.kanban</field>
        <field name="model">library.borrow.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="borrower_name"/>
                <field name="book_id"/>
                <field name="borrow_date"/>
                <field name="return_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="borrower_name"/>
                                    </strong>
                                </div>
                                <field name="state"
                                       widget="badge"
                                       decoration-success="state == 'approved'"
                                       decoration-warning="state == 'pending'"
                                       decoration-danger="state == 'rejected'"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <i class="fa fa-book me-1"/>
                                    <field name="book_id"/>
                                </div>
                                <div>
                                    <i class="fa fa-calendar me-1"/>
                                    <field name="borrow_date"/>
                                    →
                                    <field name="return_date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>