<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- HOME PAGE — /library -->
    <template id="template_library_home" name="Library Home">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">

                <!-- Page Header -->
                <div class="row mb-4">
                    <div class="col-12 text-center">
                        <h1 class="display-4">
                            📚 Library Catalogue
                        </h1>
                        <p class="lead text-muted">
                            Browse our complete book collection
                        </p>
                    </div>
                </div>

                <!-- Stats Bar -->
                <div class="row mb-4">
                    <div class="col-md-4 mb-3">
                        <div t-attf-class="card text-center border-0 shadow-sm #{
                             'border-primary border-2'
                             if active_filter == 'all' else ''}">
                            <div class="card-body py-4">
                                <h2 class="display-4 fw-bold text-primary">
                                    <t t-esc="total_books"/>
                                </h2>
                                <p class="text-muted mb-0">Total Books</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div t-attf-class="card text-center border-0 shadow-sm #{
                             'border-success border-2'
                             if active_filter == 'available' else ''}">
                            <div class="card-body py-4">
                                <h2 class="display-4 fw-bold text-success">
                                    <t t-esc="total_available"/>
                                </h2>
                                <p class="text-muted mb-0">Available Now</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div t-attf-class="card text-center border-0 shadow-sm #{
                             'border-warning border-2'
                             if active_filter == 'borrowed' else ''}">
                            <div class="card-body py-4">
                                <h2 class="display-4 fw-bold text-warning">
                                    <t t-esc="total_borrowed"/>
                                </h2>
                                <p class="text-muted mb-0">Currently Borrowed</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Search Bar -->
                <div class="row mb-4">
                    <div class="col-md-8 mx-auto">
                        <form method="GET" action="/library">
                            <div class="input-group input-group-lg shadow-sm">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="fa fa-search text-muted"/>
                                </span>
                                <input
                                    type="text"
                                    name="search"
                                    class="form-control border-start-0 ps-0"
                                    placeholder="Search by title or author..."
                                    t-att-value="search"/>
                                <t t-if="book_filter and book_filter != 'all'">
                                    <input type="hidden"
                                           name="book_filter"
                                           t-att-value="book_filter"/>
                                </t>
                                <button type="submit"
                                        class="btn btn-primary px-4">
                                    Search
                                </button>
                                <t t-if="search">
                                    <a href="/library"
                                       class="btn btn-outline-secondary">
                                        ✕ Clear
                                    </a>
                                </t>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Search results info -->
                <t t-if="search">
                    <div class="row mb-3">
                        <div class="col-12">
                            <p class="text-muted">
                                <t t-if="search_count > 0">
                                    Found
                                    <strong><t t-esc="search_count"/></strong>
                                    result(s) for
                                    "<strong><t t-esc="search"/></strong>"
                                </t>
                                <t t-else="">
                                    No results found for
                                    "<strong><t t-esc="search"/></strong>"
                                    — <a href="/library">clear search</a>
                                </t>
                            </p>
                        </div>
                    </div>
                </t>

                <!-- Filter Tabs -->
                <div class="row mb-4">
                    <div class="col-12">
                        <ul class="nav nav-tabs">
                            <li class="nav-item">
                                <a t-attf-class="nav-link #{
                                       'active fw-bold'
                                       if active_filter == 'all'
                                       else ''}"
                                   t-attf-href="/library#{
                                       '?search=' + search
                                       if search else ''}">
                                    All Books
                                    <span class="badge bg-secondary ms-1">
                                        <t t-esc="total_books"/>
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a t-attf-class="nav-link #{
                                       'active fw-bold'
                                       if active_filter == 'available'
                                       else ''}"
                                   t-attf-href="/library?book_filter=available#{
                                       '&amp;search=' + search
                                       if search else ''}">
                                    Available
                                    <span class="badge bg-success ms-1">
                                        <t t-esc="total_available"/>
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a t-attf-class="nav-link #{
                                       'active fw-bold'
                                       if active_filter == 'borrowed'
                                       else ''}"
                                   t-attf-href="/library?book_filter=borrowed#{
                                       '&amp;search=' + search
                                       if search else ''}">
                                    Borrowed
                                    <span class="badge bg-warning text-dark ms-1">
                                        <t t-esc="total_borrowed"/>
                                    </span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Books Grid -->
                <div class="row">
                    <t t-foreach="books" t-as="book">
                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card h-100 shadow-sm">

                                <!-- Cover Image -->
                                <t t-if="book.cover_image">
                                    <img t-attf-src="/web/image/library.book/#{book.id}/cover_image"
                                         class="card-img-top"
                                         style="height:200px;object-fit:cover;"
                                         t-att-alt="book.name"/>
                                </t>
                                <t t-else="">
                                    <div class="card-img-top bg-light d-flex
                                         align-items-center
                                         justify-content-center"
                                         style="height:200px;">
                                        <i class="fa fa-book fa-4x text-muted"/>
                                    </div>
                                </t>

                                <!-- Status Badge -->
                                <div class="card-header d-flex
                                     justify-content-between
                                     align-items-center">
                                    <small class="text-muted">
                                        <t t-esc="book.isbn or 'No ISBN'"/>
                                    </small>
                                    <t t-if="book.state == 'available'">
                                        <span class="badge bg-success">
                                            Available
                                        </span>
                                    </t>
                                    <t t-elif="book.state == 'borrowed'">
                                        <span class="badge bg-warning text-dark">
                                            Borrowed
                                        </span>
                                    </t>
                                    <t t-else="">
                                        <span class="badge bg-danger">
                                            Lost
                                        </span>
                                    </t>
                                </div>

                                <div class="card-body">
                                    <h5 class="card-title">
                                        <t t-esc="book.name"/>
                                    </h5>
                                    <p class="card-text text-muted mb-1">
                                        <t t-if="book.author_id">
                                            <i class="fa fa-user me-1"/>
                                            <t t-esc="book.author_id.name"/>
                                        </t>
                                        <t t-else="">
                                            <i class="fa fa-user me-1"/>
                                            Unknown Author
                                        </t>
                                    </p>
                                    <t t-if="book.pages">
                                        <small class="text-muted">
                                            <i class="fa fa-book me-1"/>
                                            <t t-esc="book.pages"/> pages
                                        </small>
                                    </t>
                                    <div class="mt-2">
                                        <small>
                                            <t t-if="book.available_copies > 0">
                                                <span class="text-success">
                                                    <i class="fa fa-check-circle me-1"/>
                                                    <t t-esc="book.available_copies"/>
                                                    of
                                                    <t t-esc="book.copy_count"/>
                                                    copies available
                                                </span>
                                            </t>
                                            <t t-else="">
                                                <span class="text-danger">
                                                    <i class="fa fa-times-circle me-1"/>
                                                    All copies borrowed
                                                </span>
                                            </t>
                                        </small>
                                    </div>
                                </div>

                                <div class="card-footer d-flex
                                     justify-content-between
                                     align-items-center">
                                    <strong class="text-primary">
                                        Rs. <t t-esc="book.price"/>
                                    </strong>
                                    <a t-attf-href="/library/book/#{book.id}"
                                       class="btn btn-sm btn-outline-primary">
                                        View Details →
                                    </a>
                                </div>

                            </div>
                        </div>
                    </t>

                    <!-- Empty state -->
                    <t t-if="not books">
                        <div class="col-12 text-center py-5">
                            <i class="fa fa-search fa-4x text-muted mb-3"/>
                            <t t-if="search">
                                <h4 class="text-muted">
                                    No books found for
                                    "<t t-esc="search"/>"
                                </h4>
                                <p class="text-muted">
                                    Try a different search term
                                </p>
                                <a href="/library"
                                   class="btn btn-primary mt-2">
                                    Clear Search
                                </a>
                            </t>
                            <t t-elif="active_filter == 'available'">
                                <h4 class="text-muted">
                                    No books available right now
                                </h4>
                                <p class="text-muted">
                                    All books are currently borrowed
                                </p>
                            </t>
                            <t t-elif="active_filter == 'borrowed'">
                                <h4 class="text-muted">
                                    No books currently borrowed
                                </h4>
                                <p class="text-muted">
                                    All books are available!
                                </p>
                            </t>
                            <t t-else="">
                                <h4 class="text-muted">
                                    No books in the library yet
                                </h4>
                            </t>
                            <a href="/library"
                               class="btn btn-primary mt-3">
                                View All Books
                            </a>
                        </div>
                    </t>

                </div>
            </div>
        </t>
    </template>

    <!--   BOOK DETAIL PAGE — /library/book/<id>   -->
    <template id="template_library_book_detail"
              name="Library Book Detail">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">

                <!-- Back button -->
                <div class="mb-4">
                    <a href="/library"
                       class="btn btn-outline-secondary">
                        ← Back to Catalogue
                    </a>
                </div>

                <div class="row">
                    <!-- Book Details -->
                    <div class="col-md-8">
                        <div class="card shadow-sm">
                                    <div class="card-header d-flex
                                         justify-content-between
                                         align-items-center">
                                        <h4 class="mb-0">Book Details</h4>
                                        <t t-if="book.state == 'available'">
                                            <span class="badge bg-success fs-6">
                                                Available
                                            </span>
                                        </t>
                                        <t t-elif="book.state == 'borrowed'">
                                            <span class="badge bg-warning text-dark fs-6">
                                                Borrowed
                                            </span>
                                        </t>
                                        <t t-else="">
                                            <span class="badge bg-danger fs-6">
                                                Lost
                                            </span>
                                        </t>
                                    </div>
                                    <div class="card-body">

                                        <!-- Cover image on detail page -->
                                        <t t-if="book.cover_image">
                                            <div class="text-center mb-4">
                                                <img t-attf-src="/web/image/library.book/#{book.id}/cover_image"
                                                     class="img-fluid rounded shadow"
                                                     style="max-height:300px;"
                                                     t-att-alt="book.name"/>
                                            </div>
                                        </t>

                                        <h2 class="mb-3">
                                            <t t-esc="book.name"/>
                                        </h2>
                                        <table class="table">
                                            <tbody>
                                                <tr>
                                                    <th width="30%">Author</th>
                                                    <td>
                                                        <t t-if="book.author_id">
                                                            <t t-esc="book.author_id.name"/>
                                                        </t>
                                                        <t t-else="">N/A</t>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th>ISBN</th>
                                                    <td>
                                                        <t t-if="book.isbn">
                                                            <t t-esc="book.isbn"/>
                                                        </t>
                                                        <t t-else="">N/A</t>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th>Pages</th>
                                                    <td>
                                                        <t t-esc="book.pages or 'N/A'"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th>Price</th>
                                                    <td>Rs. <t t-esc="book.price"/></td>
                                                </tr>
                                                <tr>
                                                    <th>Published</th>
                                                    <td>
                                                        <t t-if="book.date_published">
                                                            <t t-esc="book.date_published"/>
                                                        </t>
                                                        <t t-else="">N/A</t>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th>Copies Available</th>
                                                    <td>
                                                        <t t-esc="book.available_copies"/>
                                                        of
                                                        <t t-esc="book.copy_count"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th>Nationality</th>
                                                    <td>
                                                        <t t-esc="book.author_nationality or 'N/A'"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <t t-if="book.description">
                                            <h5 class="mt-3">Description</h5>
                                            <p class="text-muted">
                                                <t t-esc="book.description"/>
                                            </p>
                                        </t>
                                    </div>
                                </div>
                    </div>

                    <!-- Borrow Panel -->
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body text-center py-4">
                                <t t-if="book.state == 'available'">
                                    <i class="fa fa-check-circle
                                       fa-3x text-success mb-3"/>
                                    <h5>This book is available!</h5>
                                    <p class="text-muted small">
                                        Click below to borrow it
                                    </p>
                                    <a t-attf-href="/library/borrow/#{book.id}"
                                       class="btn btn-primary btn-lg w-100">
                                        Borrow This Book
                                    </a>
                                </t>
                                <t t-else="">
                                    <i class="fa fa-clock-o
                                       fa-3x text-warning mb-3"/>
                                    <h5>Not available right now</h5>
                                    <p class="text-muted small">
                                        This book is currently
                                        <t t-esc="book.state"/>
                                    </p>
                                    <a t-attf-href="/library/waitlist/#{book.id}"
                                       class="btn btn-warning
                                              text-dark fw-bold
                                              btn-lg w-100 mb-2">
                                        Join Waitlist
                                    </a>
                                    <a href="/library"
                                       class="btn btn-outline-secondary
                                              w-100">
                                        Browse Other Books
                                    </a>
                                </t>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </t>
    </template>


    <!--  BORROW FORM PAGE — /library/borrow/<id>  -->
    <template id="template_library_borrow_form"
              name="Library Borrow Form">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">

                <!-- Back button -->
                <div class="mb-4">
                    <a t-attf-href="/library/book/#{book.id}"
                       class="btn btn-outline-secondary">
                        ← Back to Book
                    </a>
                </div>

                <div class="row justify-content-center">
                    <div class="col-md-7">

                        <!-- Book info card -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-body d-flex
                                 align-items-center gap-3">
                                <i class="fa fa-book fa-3x
                                   text-primary"/>
                                <div>
                                    <h5 class="mb-0">
                                        <t t-esc="book.name"/>
                                    </h5>
                                    <small class="text-muted">
                                        <t t-if="book.author_id">
                                            by
                                            <t t-esc="book.author_id.name"/>
                                        </t>
                                    </small>
                                </div>
                            </div>
                        </div>

                        <!-- Error messages -->
                        <t t-if="error == 'missing_fields'">
                            <div class="alert alert-danger">
                                Please fill in all required fields.
                            </div>
                        </t>
                        <t t-elif="error == 'invalid_email'">
                            <div class="alert alert-danger">
                                Please enter a valid email address.
                            </div>
                        </t>
                        <t t-elif="error == 'server_error'">
                            <div class="alert alert-danger">
                                Something went wrong. Please try again.
                            </div>
                        </t>

                        <!-- Borrow Form -->
                        <div class="card shadow-sm">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    📋 Fill in your details
                                </h5>
                            </div>
                            <div class="card-body">
                                <form action="/library/borrow/submit"
                                      method="POST">

                                    <!-- CSRF token — required -->
                                    <input type="hidden"
                                           name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <input type="hidden"
                                           name="book_id"
                                           t-att-value="book.id"/>

                                    <!-- Name -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">
                                            Full Name *
                                        </label>
                                        <input type="text"
                                               name="borrower_name"
                                               class="form-control"
                                               placeholder="Enter your full name"
                                               required="required"/>
                                    </div>

                                    <!-- Email -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">
                                            Email Address *
                                        </label>
                                        <input type="email"
                                               name="borrower_email"
                                               class="form-control"
                                               placeholder="Enter your email"
                                               required="required"/>
                                    </div>

                                    <!-- Borrow Date -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">
                                            Borrow Date *
                                        </label>
                                        <input type="date"
                                               name="borrow_date"
                                               class="form-control"
                                               t-att-min="today"
                                               required="required"/>
                                    </div>

                                    <!-- Return Date -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">
                                            Return Date *
                                        </label>
                                        <input type="date"
                                               name="return_date"
                                               class="form-control"
                                               t-att-min="today"
                                               required="required"/>
                                    </div>

                                    <div class="d-grid mt-4">
                                        <button type="submit"
                                                class="btn btn-primary btn-lg">
                                            Confirm Borrow Request
                                        </button>
                                    </div>
                        <!-- Pending request warning -->
                        <t t-if="has_pending">
                            <div class="alert alert-warning">
                                <i class="fa fa-exclamation-triangle me-2"/>
                                <strong>Note:</strong>
                                There is already a pending borrow
                                request for this book. You can still
                                submit a request and the librarian
                                will process it.
                            </div>
                        </t>

                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </t>
    </template>

    <!--     SUCCESS PAGE — /library/borrow/success    -->
    <template id="template_library_borrow_success"
              name="Borrow Success">
        <t t-call="website.layout">
            <div class="container mt-5 mb-5">
                <div class="row justify-content-center">
                    <div class="col-md-6 text-center">

                        <div class="card shadow-sm py-5">
                            <div class="card-body">
                                <i class="fa fa-check-circle
                                   fa-5x text-success mb-4"/>
                                <h2 class="mb-3">
                                    Request Submitted!
                                </h2>
                                <p class="lead text-muted">
                                    Thank you,
                                    <strong>
                                        <t t-esc="borrower_name"/>
                                    </strong>!
                                </p>
                                <p class="text-muted">
                                    Your request to borrow
                                    <strong>
                                        <t t-esc="book_name"/>
                                    </strong>
                                    has been submitted successfully.
                                    The librarian will process it shortly.
                                </p>
                                <hr/>
                                <a href="/library"
                                   class="btn btn-primary me-2">
                                    Browse More Books
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </t>
    </template>

    <!--     WAITLIST FORM PAGE     -->
    <template id="template_library_waitlist_form"
              name="Library Waitlist Form">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">

                <div class="mb-4">
                    <a t-attf-href="/library/book/#{book.id}"
                       class="btn btn-outline-secondary">
                        ← Back to Book
                    </a>
                </div>

                <div class="row justify-content-center">
                    <div class="col-md-7">

                        <!-- Book info -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-body d-flex
                                 align-items-center gap-3">
                                <i class="fa fa-book fa-3x
                                   text-warning"/>
                                <div>
                                    <h5 class="mb-0">
                                        <t t-esc="book.name"/>
                                    </h5>
                                    <small class="text-muted">
                                        <t t-if="book.author_id">
                                            by
                                            <t t-esc="book.author_id.name"/>
                                        </t>
                                    </small>
                                    <div class="mt-1">
                                        <span class="badge bg-warning text-dark">
                                            Currently Borrowed
                                        </span>
                                        <span class="ms-2 text-muted small">
                                            <t t-esc="queue_length"/> people waiting
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Error messages -->
                        <t t-if="error == 'missing_fields'">
                            <div class="alert alert-danger">
                                Please fill in all required fields.
                            </div>
                        </t>
                        <t t-elif="error == 'invalid_email'">
                            <div class="alert alert-danger">
                                Please enter a valid email address.
                            </div>
                        </t>
                        <t t-elif="error == 'already_registered'">
                            <div class="alert alert-warning">
                                You are already on the waitlist
                                for this book!
                            </div>
                        </t>
                        <t t-elif="error == 'server_error'">
                            <div class="alert alert-danger">
                                Something went wrong.
                                Please try again.
                            </div>
                        </t>

                        <!-- Waitlist form -->
                        <div class="card shadow-sm">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    Join the Waitlist
                                </h5>
                            </div>
                            <div class="card-body">
                                <p class="text-muted small">
                                    We will email you as soon
                                    as this book becomes available.
                                </p>
                                <form
                                    action="/library/waitlist/submit"
                                    method="POST">
                                    <input type="hidden"
                                           name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <input type="hidden"
                                           name="book_id"
                                           t-att-value="book.id"/>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">
                                            Full Name *
                                        </label>
                                        <input type="text"
                                               name="name"
                                               class="form-control"
                                               placeholder="Your full name"
                                               required="required"/>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">
                                            Email Address *
                                        </label>
                                        <input type="email"
                                               name="email"
                                               class="form-control"
                                               placeholder="Your email"
                                               required="required"/>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">
                                            Phone (Optional)
                                        </label>
                                        <input type="text"
                                               name="phone"
                                               class="form-control"
                                               placeholder="Your phone number"/>
                                    </div>

                                    <div class="d-grid mt-4">
                                        <button type="submit"
                                                class="btn btn-warning btn-lg text-dark fw-bold">
                                            Join Waitlist
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </t>
    </template>

