<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         HOME PAGE — /library
    ============================================================ -->
    <template id="template_library_home" name="Library Home">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">

                <!-- Page Header -->
                <div class="row mb-4">
                    <div class="col-12 text-center">
                        <h1 class="display-4">
                            📚 Library Catalogue
                        </h1>
                        <p class="lead text-muted">
                            Browse our complete book collection
                        </p>
                    </div>
                </div>

                <!-- Stats Bar -->
                <div class="row mb-5">
                    <div class="col-md-4 mb-3">
                        <div class="card text-center border-0 shadow-sm">
                            <div class="card-body py-4">
                                <h2 class="display-4 fw-bold text-primary">
                                    <t t-esc="total_books"/>
                                </h2>
                                <p class="text-muted mb-0">
                                    Total Books
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card text-center border-0 shadow-sm">
                            <div class="card-body py-4">
                                <h2 class="display-4 fw-bold text-success">
                                    <t t-esc="total_available"/>
                                </h2>
                                <p class="text-muted mb-0">
                                    Available Now
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card text-center border-0 shadow-sm">
                            <div class="card-body py-4">
                                <h2 class="display-4 fw-bold text-warning">
                                    <t t-esc="total_borrowed"/>
                                </h2>
                                <p class="text-muted mb-0">
                                    Currently Borrowed
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Filter Tabs -->
                <div class="row mb-4">
                    <div class="col-12">
                        <ul class="nav nav-tabs">
                            <li class="nav-item">
                                <a t-attf-class="nav-link #{
                                       'active fw-bold' if active_filter == 'all'
                                       else ''
                                   }"
                                   href="/library">
                                    All Books
                                    <span class="badge bg-secondary ms-1">
                                        <t t-esc="total_books"/>
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a t-attf-class="nav-link #{
                                       'active fw-bold' if active_filter == 'available'
                                       else ''
                                   }"
                                   href="/library?book_filter=available">
                                    Available
                                    <span class="badge bg-success ms-1">
                                        <t t-esc="total_available"/>
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a t-attf-class="nav-link #{
                                       'active fw-bold' if active_filter == 'borrowed'
                                       else ''
                                   }"
                                   href="/library?book_filter=borrowed">
                                    Borrowed
                                    <span class="badge bg-warning text-dark ms-1">
                                        <t t-esc="total_borrowed"/>
                                    </span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
                <!-- Books Grid -->
                <div class="row">
                    <t t-foreach="books" t-as="book">
                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card h-100 shadow-sm">

                                <!-- Status ribbon -->
                                <div class="card-header d-flex
                                     justify-content-between
                                     align-items-center">
                                    <small class="text-muted">
                                        <t t-esc="book.isbn or 'No ISBN'"/>
                                    </small>
                                    <t t-if="book.state == 'available'">
                                        <span class="badge bg-success">
                                            Available
                                        </span>
                                    </t>
                                    <t t-elif="book.state == 'borrowed'">
                                        <span class="badge bg-warning text-dark">
                                            Borrowed
                                        </span>
                                    </t>
                                    <t t-else="">
                                        <span class="badge bg-danger">
                                            Lost
                                        </span>
                                    </t>
                                </div>

                                <div class="card-body">
                                    <h5 class="card-title">
                                        <t t-esc="book.name"/>
                                    </h5>
                                    <p class="card-text text-muted mb-1">
                                        <t t-if="book.author_id">
                                            <i class="fa fa-user me-1"/>
                                            <t t-esc="book.author_id.name"/>
                                        </t>
                                        <t t-else="">
                                            <i class="fa fa-user me-1"/>
                                            Unknown Author
                                        </t>
                                    </p>
                                    <t t-if="book.pages">
                                        <small class="text-muted">
                                            <i class="fa fa-book me-1"/>
                                            <t t-esc="book.pages"/> pages
                                        </small>
                                    </t>
                                </div>

                                <div class="card-footer d-flex
                                     justify-content-between
                                     align-items-center">
                                    <strong class="text-primary">
                                        Rs. <t t-esc="book.price"/>
                                    </strong>
                                    <a t-attf-href="/library/book/#{book.id}"
                                       class="btn btn-sm btn-outline-primary">
                                        View Details →
                                    </a>
                                </div>

                            </div>
                        </div>
                    </t>

                    <!-- Empty state -->
                    <t t-if="not books">
                        <div class="col-12 text-center py-5">
                            <i class="fa fa-book fa-4x text-muted mb-3"/>
                            <h4 class="text-muted">No books found</h4>
                        </div>
                    </t>
                </div>

            </div>
        </t>
    </template>

    <!-- ============================================================
         BOOK DETAIL PAGE — /library/book/<id>
    ============================================================ -->
    <template id="template_library_book_detail"
              name="Library Book Detail">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">

                <!-- Back button -->
                <div class="mb-4">
                    <a href="/library"
                       class="btn btn-outline-secondary">
                        ← Back to Catalogue
                    </a>
                </div>

                <div class="row">
                    <!-- Book Details -->
                    <div class="col-md-8">
                        <div class="card shadow-sm">
                            <div class="card-header d-flex
                                 justify-content-between
                                 align-items-center">
                                <h4 class="mb-0">Book Details</h4>
                                <t t-if="book.state == 'available'">
                                    <span class="badge bg-success fs-6">
                                        Available
                                    </span>
                                </t>
                                <t t-elif="book.state == 'borrowed'">
                                    <span class="badge bg-warning
                                          text-dark fs-6">
                                        Borrowed
                                    </span>
                                </t>
                                <t t-else="">
                                    <span class="badge bg-danger fs-6">
                                        Lost
                                    </span>
                                </t>
                            </div>
                            <div class="card-body">
                                <h2 class="mb-3">
                                    <t t-esc="book.name"/>
                                </h2>
                                <table class="table">
                                    <tbody>
                                        <tr>
                                            <th width="30%">Author</th>
                                            <td>
                                                <t t-if="book.author_id">
                                                    <t t-esc="book.author_id.name"/>
                                                </t>
                                                <t t-else="">N/A</t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>ISBN</th>
                                            <td>
                                                <t t-if="book.isbn">
                                                    <t t-esc="book.isbn"/>
                                                </t>
                                                <t t-else="">N/A</t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>Pages</th>
                                            <td>
                                                <t t-esc="book.pages or 'N/A'"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>Price</th>
                                            <td>
                                                Rs. <t t-esc="book.price"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>Published</th>
                                            <td>
                                                <t t-if="book.date_published">
                                                    <t t-esc="book.date_published"/>
                                                </t>
                                                <t t-else="">N/A</t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>Nationality</th>
                                            <td>
                                                <t t-esc="book.author_nationality or 'N/A'"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <t t-if="book.description">
                                    <h5 class="mt-3">Description</h5>
                                    <p class="text-muted">
                                        <t t-esc="book.description"/>
                                    </p>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- Borrow Panel -->
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body text-center py-4">
                                <t t-if="book.state == 'available'">
                                    <i class="fa fa-check-circle
                                       fa-3x text-success mb-3"/>
                                    <h5>This book is available!</h5>
                                    <p class="text-muted small">
                                        Click below to borrow it
                                    </p>
                                    <a t-attf-href="/library/borrow/#{book.id}"
                                       class="btn btn-primary btn-lg w-100">
                                        Borrow This Book
                                    </a>
                                </t>
                                <t t-else="">
                                    <i class="fa fa-times-circle
                                       fa-3x text-warning mb-3"/>
                                    <h5>Not available</h5>
                                    <p class="text-muted small">
                                        This book is currently
                                        <t t-esc="book.state"/>
                                    </p>
                                    <a href="/library"
                                       class="btn btn-outline-primary
                                              w-100">
                                        Browse Other Books
                                    </a>
                                </t>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </t>
    </template>

</odoo>